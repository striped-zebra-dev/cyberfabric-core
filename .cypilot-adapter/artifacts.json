{
  "version": "1.0",
  "project_root": "..",
  "kits": {
    "cf-sdlc": {
      "format": "Cypilot",
      "path": ".cypilot-adapter/kits/cf-sdlc",
      "artifacts": {
        "ADR": {
          "template": "{project_root}/docs/spec-templates/cf-sdlc/ADR/template.md",
          "examples": "{project_root}/docs/spec-templates/cf-sdlc/ADR/examples"
        },
        "DECOMPOSITION": {
          "template": "{project_root}/docs/spec-templates/cf-sdlc/DECOMPOSITION/template.md",
          "examples": "{project_root}/docs/spec-templates/cf-sdlc/DECOMPOSITION/examples"
        },
        "DESIGN": {
          "template": "{project_root}/docs/spec-templates/cf-sdlc/DESIGN/template.md",
          "examples": "{project_root}/docs/spec-templates/cf-sdlc/DESIGN/examples"
        },
        "FEATURE": {
          "template": "{project_root}/docs/spec-templates/cf-sdlc/FEATURE/template.md",
          "examples": "{project_root}/docs/spec-templates/cf-sdlc/FEATURE/examples"
        },
        "PRD": {
          "template": "{project_root}/docs/spec-templates/cf-sdlc/PRD/template.md",
          "examples": "{project_root}/docs/spec-templates/cf-sdlc/PRD/examples"
        }
      }
    }
  },
  "ignore": [
    {
      "reason": "Ignore 'modules/system' parent directory — not a module, only a grouping for system submodules.",
      "patterns": ["modules/system"]
    },
    {
      "reason": "Ignore 'modules/system/authn-resolver' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/authn-resolver/*"]
    },
    {
      "reason": "Ignore 'modules/system/authz-resolver' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/authz-resolver/*"]
    },
    {
      "reason": "Ignore module 'api-gateway' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/api-gateway/*"]
    },
    {
      "reason": "Ignore module 'grpc-hub' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/grpc-hub/*"]
    },
    {
      "reason": "Ignore module 'module-orchestrator' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/module-orchestrator/*"]
    },
    {
      "reason": "Ignore module 'nodes-registry' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/nodes-registry/*"]
    },
    {
      "reason": "Ignore legacy (pre-Cypilot) ADR files in oagw/docs root — converted copies live under docs/ADR/.",
      "patterns": ["modules/system/oagw/docs/adr-*.md"]
    },
    {
      "reason": "Ignore module 'tenant-resolver' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/tenant-resolver/*"]
    },
    {
      "reason": "Ignore module 'types' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/types/*"]
    },
    {
      "reason": "Ignore module 'types-registry' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/types-registry/*"]
    },
    {
      "reason": "Ignore module 'types-sdk' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/system/types-sdk/*"]
    },
    {
      "reason": "Ignore module 'simple-user-settings' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/simple-user-settings/*"]
    },
    {
      "reason": "Ignore module 'file-storage' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/file-storage/*"]
    },
    {
      "reason": "Ignore module 'model-registry' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/model-registry/*"]
    },
    {
      "reason": "Ignore module 'types-registry' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/types-registry/*"]
    },
    {
      "reason": "Ignore module 'file-parser' (not SDLC-documented yet: missing required PRD/DESIGN).",
      "patterns": ["modules/file-parser/*"]
    },
    {
      "reason": "Ignore module 'serverless-runtime' (not SDLC-documented yet: missing required PRD/DESIGN and ID prefix alignment).",
      "patterns": ["modules/serverless-runtime/*"]
    },
    {
      "reason": "Ignore module 'mini-chat' docs (temporary: PRD/DESIGN constraints failing in CI).",
      "patterns": ["modules/mini-chat/*"]
    },
    {
      "reason": "Ignore module 'approval-service' (not SDLC-documented yet: PRD/DESIGN are placeholders).",
      "patterns": ["modules/approval-service/*"]
    }
  ],
  "systems": [
    {
      "name": "cyberfabric",
      "slug": "cf",
      "kit": "cf-sdlc",
      "artifacts": [
        { "path": "docs/arch/errors/PRD.md", "kind": "PRD", "traceability": "DOCS-ONLY" },
        { "path": "docs/arch/errors/DESIGN.md", "kind": "DESIGN", "traceability": "DOCS-ONLY" },
        { "path": "docs/arch/errors/DECOMPOSITION.md", "kind": "DECOMPOSITION", "traceability": "DOCS-ONLY" },
        { "path": "docs/arch/errors/ADR/0001-cpt-cf-adr-canonical-error-categories.md", "kind": "ADR", "traceability": "DOCS-ONLY" },
        { "path": "docs/arch/errors/ADR/0002-cpt-cf-adr-gts-error-identification.md", "kind": "ADR", "traceability": "DOCS-ONLY" },
        { "path": "docs/arch/errors/ADR/0003-cpt-cf-adr-rfc9457-wire-format.md", "kind": "ADR", "traceability": "DOCS-ONLY" },
        { "path": "docs/arch/errors/ADR/0004-cpt-cf-adr-typed-enum-impl.md", "kind": "ADR", "traceability": "DOCS-ONLY" }
      ],
      "artifacts_dir": "docs",
      "codebase": [
        { "name": "Apps", "path": "apps", "extensions": [".rs"] },
        { "name": "Libraries", "path": "libs", "extensions": [".rs"] },
        { "name": "Examples", "path": "examples", "extensions": [".rs"] },
        { "name": "Dylint Lints", "path": "dylint_lints", "extensions": [".rs"] },
        { "name": "E2E Testing", "path": "testing", "extensions": [".py"] }
      ],
      "autodetect": [
        {
          "system_root": "{project_root}/modules/$system",
          "artifacts_root": "{system_root}/docs",
          "artifacts": {
            "PRD": { "pattern": "PRD.md", "traceability": "FULL", "required": true },
            "DESIGN": { "pattern": "DESIGN.md", "traceability": "FULL", "required": true },
            "ADR": { "pattern": "ADR/*.md", "traceability": "FULL", "required": false },
            "DECOMPOSITION": { "pattern": "DECOMPOSITION.md", "traceability": "FULL", "required": false },
            "FEATURE": { "pattern": "features/*.md", "traceability": "FULL", "required": false }
          },
          "codebase": [
            { "name": "Modules", "path": "{system_root}/src", "extensions": [".rs"] },
            { "name": "Tests", "path": "{system_root}/tests", "extensions": [".rs"] }
          ],
          "validation": {
            "require_kind_registered_in_kit": true,
            "require_md_extension": true,
            "fail_on_unmatched_markdown": true
          }
        },
        {
          "system_root": "{project_root}/modules/system/$system",
          "artifacts_root": "{system_root}/docs",
          "artifacts": {
            "PRD": { "pattern": "PRD.md", "traceability": "FULL", "required": true },
            "DESIGN": { "pattern": "DESIGN.md", "traceability": "FULL", "required": true },
            "ADR": { "pattern": "ADR/*.md", "traceability": "FULL", "required": false },
            "DECOMPOSITION": { "pattern": "DECOMPOSITION.md", "traceability": "FULL", "required": false },
            "FEATURE": { "pattern": "features/*.md", "traceability": "FULL", "required": false }
          },
          "codebase": [
            { "name": "Modules", "path": "{system_root}/src", "extensions": [".rs"] },
            { "name": "Tests", "path": "{system_root}/tests", "extensions": [".rs"] }
          ],
          "validation": {
            "require_kind_registered_in_kit": true,
            "require_md_extension": true,
            "fail_on_unmatched_markdown": true
          }
        }
      ]
    },
    {
      "name": "examples",
      "slug": "examples",
      "kit": "cf-sdlc",
      "artifacts_dir": "docs/spec-templates/examples/",
      "autodetect": [
        {
          "system_root": "{project_root}/docs/spec-templates/examples/$system",
          "artifacts_root": "{system_root}",
          "artifacts": {
            "PRD": { "pattern": "PRD.md", "traceability": "DOCS-ONLY", "required": true },
            "DESIGN": { "pattern": "DESIGN.md", "traceability": "DOCS-ONLY", "required": true },
            "ADR": { "pattern": "ADR/*.md", "traceability": "DOCS-ONLY", "required": false },
            "DECOMPOSITION": { "pattern": "DECOMPOSITION.md", "traceability": "DOCS-ONLY", "required": false },
            "FEATURE": { "pattern": "features/*.md", "traceability": "DOCS-ONLY", "required": false }
          },
          "codebase": [],
          "validation": {
            "require_kind_registered_in_kit": true,
            "require_md_extension": true,
            "fail_on_unmatched_markdown": true
          }
        }
      ],
      "children": [],
      "codebase": []
    }
  ]
}
